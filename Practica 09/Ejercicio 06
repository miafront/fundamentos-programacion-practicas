#include <iostream>
#include <string>
using namespace std;
string eliminarvocales(string texto){
for(int i=0;i<texto.length();i++){
if(texto.at(i)=='a' || texto.at(i)=='e' ||
texto.at(i)=='i' || texto.at(i)=='o' ||
texto.at(i)=='u'){
texto.erase(i,1);
i--;
}
}
return texto;
}
int main(){
string texto;
getline(cin,texto);
cout<<eliminarvocales(texto);
return 0;
}
