#include <iostream>
#include <string>
using namespace std;
bool espalindromo(string texto){
for(int i=0;i<texto.length()/2;i++){
if(texto.at(i)!=texto.at(texto.length()-1-i))
return false;
}
return true;
}
int main(){
string texto;
cin>>texto;
if(espalindromo(texto))
cout<<"true";
else
cout<<"false";
return 0;
}
