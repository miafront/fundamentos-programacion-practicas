#include <iostream>
#include <string>
#include <cctype>
using namespace std;
string convertir(string texto){
texto[0]=toupper(texto[0]);
for(int i=1;i<texto.length();i++)
if(texto[i-1]==' ')
texto[i]=toupper(texto[i]);
return texto;
}
int main(){
string texto;
getline(cin,texto);
cout<<convertir(texto);
return 0;
}
