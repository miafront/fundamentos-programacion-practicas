#include <iostream>
#include <string>
using namespace std;
string borracaracterdecadena(string texto,char c){
for(int i=0;i<texto.length();i++){
if(texto.at(i)==c){
texto.erase(i,1);
i--;
}
}
return texto;
}
int main(){
string texto;
char c;
getline(cin,texto);
cin>>c;
cout<<borracaracterdecadena(texto,c);
return 0;
}
