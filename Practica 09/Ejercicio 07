#include <iostream>
#include <string>
using namespace std;
void ordenar(string &palabra){
char aux;
for(int i=0;i<palabra.length()-1;i++){
for(int j=i+1;j<palabra.length();j++){
if(palabra.at(i)>palabra.at(j)){
aux=palabra.at(i);
palabra.at(i)=palabra.at(j);
palabra.at(j)=aux;
}
}
}
}
int main(){
string palabra;
cin>>palabra;
ordenar(palabra);
cout<<palabra;
return 0;
}
