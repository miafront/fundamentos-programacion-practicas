#include <iostream>
#include <string>
using namespace std;
int contarpalabras(string texto){
int palabras=1;
for(int i=0;i<texto.length();i++)
if(texto.at(i)==' ')
palabras++;
return palabras;
}
int main(){
string texto;
getline(cin,texto);
cout<<contarpalabras(texto)<<" palabras";

    return 0;
}
