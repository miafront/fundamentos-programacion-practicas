#include <iostream>
using namespace std;
int main(){
float a,b,c,d,e,f;
float det,x,y;
cin >> a >> b >> c;
cin >> d >> e >> f;
det = a*e - b*d;
if(det != 0){
x = (c*e - b*f) / det;
y = (a*f - c*d) / det;
cout << "X = " << x << endl;
cout << "Y = " << y << endl;
}
else{
cout << "No tiene solucion unica";
}
return 0;
}
