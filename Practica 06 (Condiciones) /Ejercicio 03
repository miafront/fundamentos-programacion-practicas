#include <iostream>
using namespace std;
int main() {
int N, u, d, c, m;
cout << "Ingrese un numero menor a 10000: ";
cin >> N;
u = N % 10;
d = (N / 10) % 10;
c = (N / 100) % 10;
m = (N / 1000) % 10;
cout << "Unidades: " << u << endl;
cout << "Decenas: " << d << endl;
cout << "Centenas: " << c << endl;
cout << "Miles: " << m << endl;
return 0;
}
