#include <iostream>
using namespace std;
int main() {
float P;
cout << "Ingrese el peso de la carta: ";
cin >> P;
if (P > 0 && P <= 50)
cout << "Costo: Bs. 1.50";
else if (P <= 100)
cout << "Costo: Bs. 4.00";
else if (P <= 200)
cout << "Costo: Bs. 6.00";
else if (P <= 350)
cout << "Costo: Bs. 10.50";
else if (P <= 500)
cout << "Costo: Bs. 15.00";
else
cout << "NO PUEDE ENVIAR COMO CARTA";
return 0;
}
