#include <iostream>
using namespace std;
int mayorDiferencia(int v[],int n){
int mayor=abs(v[1]-v[0]);
for(int i=1;i<n-1;i++){
int dif=abs(v[i+1]-v[i]);
if(dif>mayor)
mayor=dif;
}
return mayor;
}
int main(){
int n,v[100];
cin>>n;
for(int i=0;i<n;i++)
cin>>v[i];
cout<<mayorDiferencia(v,n);
return 0;
}
