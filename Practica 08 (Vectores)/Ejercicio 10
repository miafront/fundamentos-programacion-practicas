#include <iostream>
using namespace std;
void intercalar(int a[],int n,int b[],int m,int c[]){
int i=0,j=0,k=0;
while(i<n && j<m){
if(a[i]<b[j])
c[k++]=a[i++];
else
c[k++]=b[j++];
}
while(i<n)
c[k++]=a[i++];
while(j<m)
c[k++]=b[j++];
}
int main(){
int n,m;
int a[100],b[100],c[200];
cin>>n;
for(int i=0;i<n;i++)
cin>>a[i];
cin>>m;
for(int i=0;i<m;i++)
cin>>b[i];
intercalar(a,n,b,m,c);
for(int i=0;i<n+m;i++)
cout<<c[i]<<" ";
return 0;
}
