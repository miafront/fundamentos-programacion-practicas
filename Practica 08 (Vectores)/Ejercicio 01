#include <iostream>
using namespace std;
int maximo(int v[],int n){
    int mayor=v[0];
    for(int i=1;i<n;i++)
        if(v[i]>mayor)
            mayor=v[i];

    return mayor;
}
int main(){
    int n,v[100];
    cin>>n;
    for(int i=0;i<n;i++)
        cin>>v[i];
    cout<<maximo(v,n);
    return 0;
}
