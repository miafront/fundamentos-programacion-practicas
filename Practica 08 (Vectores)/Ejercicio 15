#include <iostream>
#include <string>
using namespace std;
void ordenar(string alumnos[],float notas[],int n){
float auxnota;
string auxalumno;
for(int i=0;i<n-1;i++){
for(int j=i+1;j<n;j++){
if(notas[i]<notas[j]){
auxnota=notas[i];
notas[i]=notas[j];
notas[j]=auxnota;
auxalumno=alumnos[i];
alumnos[i]=alumnos[j];
alumnos[j]=auxalumno;
}
}
}
}
int main(){
int n;
string alumnos[100];
float notas[100];
cin>>n;
for(int i=0;i<n;i++){
cin>>alumnos[i];
cin>>notas[i];
}
ordenar(alumnos,notas,n);
cout<<"Las tres mejores notas son:"<<endl;
for(int i=0;i<3 && i<n;i++)
cout<<alumnos[i]<<" "<<notas[i]<<endl;
return 0;
}
