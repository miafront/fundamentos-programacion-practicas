#include <iostream>
using namespace std;
void concatenar(int a[],int n,int b[],int m,int c[]){
for(int i=0;i<n;i++)
c[i]=a[i];
for(int i=0;i<m;i++)
c[n+i]=b[i];
}
int main(){
int n,m;
int a[100],b[100],c[200];
cin>>n;
for(int i=0;i<n;i++)
cin>>a[i];
cin>>m;
for(int i=0;i<m;i++)
cin>>b[i];
concatenar(a,n,b,m,c);
for(int i=0;i<n+m;i++)
cout<<c[i]<<" ";
return 0;
}
