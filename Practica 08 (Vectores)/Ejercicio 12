#include <iostream>
using namespace std;
void eliminarduplicados(int v[],int &n){
for(int i=0;i<n;i++){
for(int j=i+1;j<n;j++){
if(v[i]==v[j]){
for(int k=j;k<n-1;k++)
v[k]=v[k+1];
n--;
j--;
}
}
}
}
int main(){
int n,v[100];
cin>>n;
for(int i=0;i<n;i++)
cin>>v[i];
eliminarduplicados(v,n);
for(int i=0;i<n;i++)
cout<<v[i]<<" ";
return 0;
}
