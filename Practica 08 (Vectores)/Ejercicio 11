#include <iostream>
using namespace std;
void contar(int v[],int n,int &pos,int &neg,int &cer){
pos=0;
neg=0;
cer=0;
for(int i=0;i<n;i++){
if(v[i]>0)
pos++;
else if(v[i]<0)
neg++;
else
cer++;
}
}
int main(){
int n,v[100];
int pos,neg,cer;
cin>>n;
for(int i=0;i<n;i++)
cin>>v[i];
contar(v,n,pos,neg,cer);
cout<<"Positivos: "<<pos<<endl;
cout<<"Negativos: "<<neg<<endl;
cout<<"Ceros: "<<cer;
return 0;
}
