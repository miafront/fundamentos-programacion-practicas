#include <iostream>
#include <math.h>
using namespace std;
int diastotales(int dia, int mes, int anio)
{
    int total = 0;
    total = total + (anio * 365);
    total = total + (anio / 4);
    for(int i = 1; i < mes; i++)
    {
        if(i == 2)
        {
        total = total + 28;
        }
        else if(i == 4 || i == 6 || i == 9 || i == 11)
        {
        total = total + 30;
        }
        else
        {
        total = total + 31;
        }
    }
    total = total + dia;
    return total;
}
int main()
{
    int d1, m1, a1;
    int d2, m2, a2;
    int dias1, dias2, diferencia;
    cout << "Primera fecha" << endl;
    cin >> d1 >> m1 >> a1;
    cout << "Segunda fecha" << endl;
    cin >> d2 >> m2 >> a2;
    dias1 = diastotales(d1, m1, a1);
    dias2 = diastotales(d2, m2, a2);
    diferencia = abs(dias2 - dias1);
    cout << "Dias transcurridos: " << diferencia;
    return 0;
}
