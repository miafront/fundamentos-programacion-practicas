#include <iostream>
using namespace std;
int factorial(int n)
{
    int resultado = 1;
    for(int i = 1; i <= n; i++)
    {
        resultado = resultado * i;
    }
    return resultado;
}
int main()
{
    int n, r;
    int c;
    cout << "Ingrese n: ";
    cin >> n;
    cout << "Ingrese r: ";
    cin >> r;
    c = factorial(n) / (factorial(r) * factorial(n - r));
    cout << "Combinatorio = " << c;
    return 0;
}
